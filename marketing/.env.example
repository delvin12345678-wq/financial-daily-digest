# MarketDaily 社群自動發文設定
# 複製此檔為 .env(同資料夾),填入你的權杖。.env 不會被 git 追蹤。
# 取得每個值的逐步教學見 SETUP_AUTOPOST.md。

# ── Meta(Facebook 粉專 + Instagram 共用一組長期權杖)──
META_ACCESS_TOKEN=
FB_PAGE_ID=
IG_USER_ID=

# ── Threads(獨立權杖)──
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=

# ── LINE 官方帳號 ──
LINE_CHANNEL_ACCESS_TOKEN=

# ── 網站(貼文圖片的公開網址前綴,通常不用改)──
SITE_BASE=https://marketdaily.ai

# ── X / Twitter(選配。developer.x.com 建 App,權限設 Read and write)──
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# ── YouTube(選配。跑 get_youtube_token.py 取得這三個值)──
YT_CLIENT_ID=
YT_CLIENT_SECRET=
YT_REFRESH_TOKEN=
